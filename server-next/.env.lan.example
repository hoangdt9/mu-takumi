# Replace YOUR_LAN_IP with this machine's Wi‑Fi / Ethernet IP (same subnet as the phone).
TAKUMI_PUBLIC_HOST=192.168.1.50
# USB adb reverse (no Wi‑Fi to Mac): ./scripts/adb-reverse.sh + APK -PmuBootstrapAdbReverse=true; then set both to 127.0.0.1:
# TAKUMI_PUBLIC_HOST=127.0.0.1
# TAKUMI_LAN_IP=127.0.0.1

# Android Preload: full URL for data.zip (Gradle → BuildConfig). Use the same host as TAKUMI_PUBLIC_HOST + datazip port.
# If unset, Gradle builds http://TAKUMI_PUBLIC_HOST:DATA_ZIP_PUBLISH_PORT/data.zip (port default 18080).
TAKUMI_DATA_ZIP_URL=http://YOUR_LAN_IP:18080/data.zip

# Optional: when TAKUMI_PUBLIC_HOST is unset (local Gradle only), override emulator data.zip URL instead of the built-in default.
# TAKUMI_EMULATOR_DATA_ZIP_URL=http://10.0.2.2:18080/data.zip
TAKUMI_CONNECT_PORT=44605
TAKUMI_LOGIN_PORT=44606
# M5: advertised game port in F4 03 (defaults to TAKUMI_LOGIN_PORT when unset).
# M6 split stack (LAN + game-host): set BOTH; one command: ./scripts/docker-stack-lan-gamehost.sh
TAKUMI_GAME_PORT=55901
TAKUMI_GAME_PUBLISH=55901
# TAKUMI_SESSION_TICKET_TTL_MINUTES=120

# Connect-server sub-lines (F4 06): client maps each wire id → ServerList.bmd group via (id/20).
# If your BMD does not match the host default, set one of:
#   TAKUMI_CS_CONNECT_IDS=0,1,2,20,21,22
#   TAKUMI_CS_CONNECT_BASE=20
#   TAKUMI_CS_CONNECT_COUNT=3
# (BASE+COUNT only when at least one of those vars is set in .env; docker-compose no longer forces BASE=20.)

# Optional: overrides for `server-next/docker-compose.yml` (Postgres publish / credentials)
# TAKUMI_POSTGRES_PUBLISH_PORT=54444
# TAKUMI_PG_USER=takumi
# TAKUMI_PG_PASSWORD=takumi
# TAKUMI_PG_DATABASE=takumi_runtime

# M4b — JSON ↔ Postgres roster (`character_roster` table; see `sql/init/001_character_roster.sql`).
# When sync is on, hosts also read `inventory_slot` (`sql/init/002_inventory_slot.sql`) for post-join F3 10 (12-byte `item` per row).
# In Docker, from legacy-login container use Host=postgres;Port=5432;… On host `dotnet run`, use Host=localhost;Port=TAKUMI_POSTGRES_PUBLISH_PORT.
# TAKUMI_ROSTER_DB_SYNC=1
# TAKUMI_ROSTER_DB_PRIMARY=1
# TAKUMI_ROSTER_JSON_EXPORT=1
# TAKUMI_CHARACTER_DOMAIN_SYNC=1
# Apply once on existing DB volume: ./scripts/apply-sql.sh 'postgresql://takumi:takumi@127.0.0.1:54444/takumi_runtime'
# TAKUMI_PG_CONNECTION_STRING=Host=postgres;Port=5432;Username=takumi;Password=takumi;Database=takumi_runtime
# Or: TAKUMI_PG_HOST=localhost  TAKUMI_PG_PORT=54444  (same user/password/db as postgres service)
# Docker stack: compose sets TAKUMI_DOCKER_STACK=1; hosts rewrite PG to postgres:5432 after .env load.
# Split-port Android (F4 03 → TAKUMI_GAME_PORT): game-host clears TAKUMI_GAME_REQUIRE_LOGIN_HANDOFF unless
# TAKUMI_DOCKER_GAMEHOST_REQUIRE_HANDOFF=1 (login on game TCP, not legacy 44606).
# Optional: periodic JSON+DB flush on walk/instant move (seconds, 5..3600)
# TAKUMI_ROSTER_PERIODIC_SAVE_SECONDS=60
# TAKUMI_ROSTER_DB_MERGE_MODE=overlay   # or "json" = skip DB overlay after login
# M4b: stderr snapshot of roster merge_ok / merge_fail / upsert_ok / upsert_fail after TryDrainPendingUpserts (disconnect)
# TAKUMI_ROSTER_HEALTH_LOG=1
# M6: always log [event=decrypted_rx] on stderr (without TAKUMI_VERBOSE)
# TAKUMI_STRUCTURED_LOG=1

# Optional: LAN static HTTP for Android Preload data.zip (nginx). Default host port 18080 — not 44605/44606.
# Use compose profile `datazip` (docker-stack bật mặc định): ./scripts/docker-stack.sh --detach
# File:   takumi/docker/data-zip/host/data.zip
# URL:    http://<TAKUMI_LAN_IP>:18080/data.zip
# DATA_ZIP_PUBLISH_PORT=18080
# TAKUMI_DATA_ZIP_HOST_DIR=../docker/data-zip/host
# TAKUMI_DATA_ZIP_NGINX_CONF=../docker/data-zip/default.conf

# M5 split-stack handoff (Postgres session_ticket; see sql/init/003_session_ticket.sql + docs/M5-JOIN-HANDOFF-CHECKLIST.md)
# TAKUMI_SESSION_HANDOFF_DB=1
# TAKUMI_GAME_REQUIRE_LOGIN_HANDOFF=1   # on GameHost process only
# TAKUMI_GAME_HANDOFF_MATCH_IP=0
# Signed session ticket on wire (F1 A5 / F1 A6); set the same HMAC key on legacy-login + game-host
# TAKUMI_SESSION_TICKET_HMAC_KEY=change-me-8chars-min
# TAKUMI_GAME_TICKET_WIRE=1

# M8 — monster_spawn ETL (apply sql/init/005_monster_spawn.sql; import via ./scripts/import-monster-spawn.sh)
# TAKUMI_MONSTER_SPAWN_DB=1
# TAKUMI_MONSTER_SET_BASE_PATH=/path/to/MuServer/4.GameServer/Data/Monster/MonsterSetBase.txt
# M9 file paths (used when DB off or monster_spawn empty):
# TAKUMI_MONSTER_INFO_PATH=/path/to/Monster/Monster.txt

# M8 — gates / shops / Custom (apply sql/init/006; ./scripts/import-world-static-data.sh)
# TAKUMI_GAMESERVER_DATA_PATH=/path/to/MuServer/4.GameServer/Sub 1/Data
# TAKUMI_WORLD_STATIC_DB=1
# Or per-table: TAKUMI_MAP_GATE_DB=1  TAKUMI_NPC_SHOP_DB=1  TAKUMI_CUSTOM_WORLD_DB=1
# TAKUMI_GATE_PATH=/path/to/Move/Gate.txt

# Dec2.dat: commit server-next/keys/Dec2.dat (see keys/README.txt) OR set paths below.
# Host `dotnet run` / ./scripts/run-legacy-login-host.sh auto-use server-next/keys/Dec2.dat when present.
# Optional: colon-separated extra files to try if keys/Dec2.dat is missing (no hardcoded machine paths in scripts).
# TAKUMI_DEC2_FALLBACK_PATHS=../ClientBuild_192.168.99.200/Data/Dec2.dat:/abs/other/Data/Dec2.dat
# TAKUMI_DEC2_PATH=/absolute/path/to/.../Data/Dec2.dat
# Optional alias (same Dec2.dat): checked first by key loader — see IMPLEMENTATION-CHECKLIST / Season6ClientToServerDecryptSession
# TAKUMI_SIMPLEMODULUS_CS_DEC_KEY_PATH=/absolute/path/to/.../Data/Dec2.dat
# Post-decrypt DoS guards (LegacyLoginHost + GamePortMinimalSession)
# TAKUMI_MAX_DECRYPTED_PACKET_BYTES=12288
# TAKUMI_MAX_PACKETS_PER_SECOND=400

# M10 — map presence broadcast (two-client QA)
# TAKUMI_MAP_PRESENCE_ENABLED=1
# TAKUMI_PRESENCE_MAX_BROADCASTS_PER_SECOND=60
# Docker mounts TAKUMI_DEC2_HOST_DIR (default ./keys) -> /keys; container uses TAKUMI_DEC2_PATH=/keys/Dec2.dat
# TAKUMI_DEC2_HOST_DIR=./keys
