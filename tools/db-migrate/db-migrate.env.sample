# Copy this file to: tools/db-migrate/.env  (ignored by git, see root .gitignore)
#
# MSSQL Takumi MuOnline restore + Postgres OpenMU (same compose / local).
# Bash scripts sourcing this must use POSIX KEY=value lines (optional quotes).

TAKUMI_MSSQL_CONNECTION=Server=127.0.0.1,1433;Database=MuOnline;User Id=sa;Password=CHANGE_ME;TrustServerCertificate=True
TAKUMI_PG_CONNECTION=Host=127.0.0.1;Port=5432;Database=openmu;Username=postgres;Password=admin
